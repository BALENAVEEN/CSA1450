#include <stdio.h>
#include <string.h>

struct Symbol
{
    char name[20];
};

int main()
{
    struct Symbol s[10];
    int n, i;

    printf("Enter number of identifiers: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        printf("Enter identifier %d: ", i + 1);
        scanf("%s", s[i].name);
    }

    printf("\nSymbol Table\n");
    printf("-------------\n");
    for(i = 0; i < n; i++)
    {
        printf("%d\t%s\n", i + 1, s[i].name);
    }

    return 0;
}
