#include <stdio.h>
#include <string.h>

int main()
{
    char exp[20];
    int temp = 1;

    printf("Enter expression (e.g., a+b*c): ");
    scanf("%s", exp);

    printf("\nThree Address Code:\n");

    printf("t%d = %c * %c\n", temp, exp[2], exp[4]);
    printf("t%d = %c + t%d\n", temp + 1, exp[0], temp);
    printf("Result = t%d\n", temp + 1);

    return 0;
}
