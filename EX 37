%{
#include<stdio.h>
#include<string.h>

int count = 0;
char word[] = "compiler";
%}

%%

[a-zA-Z]+ {
    if(strcmp(yytext, word) == 0)
        count++;
}

[ \t\n] ;

. ;

%%

int yywrap()
{
    return 1;
}

int main()
{
    printf("Enter a sentence:\n");
    yylex();

    printf("Frequency of '%s' = %d\n", word, count);

    return 0;
}
