%{
#include<stdio.h>
#include<stdlib.h>

int a, b;
%}

%%

[0-9]+[+][0-9]+ {
    sscanf(yytext,"%d+%d",&a,&b);
    printf("Addition = %d\n", a+b);
}

[0-9]+[-][0-9]+ {
    sscanf(yytext,"%d-%d",&a,&b);
    printf("Subtraction = %d\n", a-b);
}

[0-9]+[*][0-9]+ {
    sscanf(yytext,"%d*%d",&a,&b);
    printf("Multiplication = %d\n", a*b);
}

[0-9]+[/][0-9]+ {
    sscanf(yytext,"%d/%d",&a,&b);
    printf("Division = %d\n", a/b);
}

%%

int yywrap()
{
    return 1;
}

int main()
{
    printf("Enter Expression: ");
    yylex();
    return 0;
}
